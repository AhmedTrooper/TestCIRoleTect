{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Roletect",
  "version": "0.1.4",
  "identifier": "com.ahmedtrooper.roletect",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Roletect",
        "width": 1200,
        "height": 800,
        "decorations": false,
        "shadow": true,
        "resizable": true,
        "zoomHotkeysEnabled": false
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      },
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
